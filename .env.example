# --- Core ---
DATABASE_URI=postgres://legalos:legalos@localhost:5432/legalos
PAYLOAD_SECRET=replace-with-a-long-random-string
NEXT_PUBLIC_SERVER_URL=https://mo.legenex.com
LEGALOS_FALLBACK_HOST=mo.legenex.com

# --- Super admin (used by seed script only) ---
SUPER_ADMIN_EMAIL=team@legenex.com
SUPER_ADMIN_PASSWORD=change-me-on-first-login

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- AI ---
ANTHROPIC_API_KEY=

# --- Email (Resend or SMTP, optional) ---
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@legenex.com
SMTP_FROM_NAME=Legenex LegalOS

# --- HLR phone enrichment (optional) ---
HLR_PROVIDER=plivo
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# --- Plesk REST API (used to provision tenant domains on connect) ---
# Plesk admin API base URL. Default port is 8443 for Plesk on Linux.
PLESK_API_URL=https://your-plesk-host:8443
# Generate at: Plesk → Tools & Settings → API Keys → Add API Key
PLESK_API_KEY=
# Where Plesk's nginx should reverse-proxy tenant domains. Should point at this app.
PLESK_PROXY_TARGET=http://127.0.0.1:3000
# Plesk reseller / admin login that will own the auto-created tenant domains.
PLESK_OWNER_LOGIN=admin
# Email used for Let's Encrypt registration on tenant domains.
PLESK_OWNER_EMAIL=team@legenex.com
# Public IP of the Plesk server (optional — Plesk uses it as the bind IP for new domains).
PLESK_IP_ADDRESS=

# --- Domain system ---
# Preview subdomain pattern: every Site gets {slug}.LEGALOS_PREVIEW_DOMAIN auto-issued.
# Requires *.LEGALOS_PREVIEW_DOMAIN wildcard DNS pointing at the Plesk server IP.
LEGALOS_PREVIEW_DOMAIN=preview.legenex.com

# Hostname tenants point their custom domains at. Should be the LegalOS app hostname
# (mo.legenex.com), which already resolves to the Plesk server.
LEGALOS_CNAME_TARGET=mo.legenex.com

# Server IP for tenants who can't CNAME (apex domains on registrars without ALIAS).
LEGALOS_A_TARGET=

# Local-dev escape hatch: when "true", DNS verification can be skipped via a button.
# MUST be false in production.
LEGALOS_DEV_SKIP_DNS=false
